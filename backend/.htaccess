Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Don't process actual directories and files
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything to index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

<IfModule !mod_rewrite.c>
    # If mod_rewrite is not enabled, you'll need to use this alternative
    # Or contact your hosting provider to enable mod_rewrite
</IfModule>
