{
	"info": {
		"name": "Therapy Booking API (Manual Complete)",
		"_postman_id": "full-manual-collection",
		"description": "Full API collection reflecting all active and planned backend routes (44+ endpoints). Base URL: http://localhost/Cosmic-tech/backend. After login, copy 'token' from the response and paste it into the 'token' collection variable.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost/Cosmic-tech/backend" },
		{ "key": "token", "value": "" },
		{ "key": "doctorId", "value": "1" },
		{ "key": "appointmentId", "value": "1" },
		{ "key": "slotId", "value": "1" },
		{ "key": "messageId", "value": "1" }
	],
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register (Client)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": "{{baseUrl}}/api/auth/register",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"userType\": \"client\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "Register a new client. userType must be 'client' or 'doctor'. Returns userId, token, refreshToken, onboarding_step."
					}
				},
				{
					"name": "Register (Doctor)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": "{{baseUrl}}/api/auth/register",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"Dr. John Smith\",\n  \"email\": \"drjohn@example.com\",\n  \"password\": \"password123\",\n  \"userType\": \"doctor\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "Register a new doctor. After registration, call POST /api/doctors/setup to complete the profile."
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": "{{baseUrl}}/api/auth/login",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "Login. Response includes: userId, fullName, email, userType, token, refreshToken, is_profile_completed, onboarding_step. Copy 'token' to the collection variable."
					}
				},
				{
					"name": "Get Me (Current User)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/auth/me",
						"description": "Returns the currently authenticated user's profile from the JWT token."
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/auth/logout",
						"description": "Stateless JWT logout. Client must discard the token after this call."
					}
				}
			]
		},
		{
			"name": "2. Doctors",
			"item": [
				{
					"name": "Setup Doctor Profile",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/doctors/setup",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "gender", "value": "male", "type": "text", "description": "male | female | other" },
								{ "key": "dateOfBirth", "value": "1980-06-15", "type": "text", "description": "YYYY-MM-DD" },
								{ "key": "phoneNumber", "value": "+12025551234", "type": "text" },
								{ "key": "primarySpecialty", "value": "Psychiatry", "type": "text" },
								{ "key": "subSpecializations", "value": "[\"Anxiety\", \"Depression\"]", "type": "text", "description": "JSON-encoded array string" },
								{ "key": "yearsOfExperience", "value": "10", "type": "text" },
								{ "key": "licenseNumber", "value": "LIC-2024-001", "type": "text" },
								{ "key": "languagesSpoken", "value": "[\"English\", \"Spanish\"]", "type": "text", "description": "JSON-encoded array string" },
								{ "key": "videoEnabled", "value": "true", "type": "text", "description": "true | false" },
								{ "key": "videoRate", "value": "80", "type": "text", "description": "Rate per session in USD" },
								{ "key": "audioEnabled", "value": "false", "type": "text" },
								{ "key": "audioRate", "value": "", "type": "text", "description": "Optional" },
								{ "key": "consultationDuration", "value": "60min", "type": "text", "description": "30min | 45min | 60min" },
								{ "key": "bufferTime", "value": "10min", "type": "text", "description": "5min | 10min | 15min | 30min" },
								{ "key": "streetAddress", "value": "123 Health St", "type": "text", "description": "Optional" },
								{ "key": "city", "value": "New York", "type": "text", "description": "Optional" },
								{ "key": "state", "value": "NY", "type": "text", "description": "Optional" },
								{ "key": "country", "value": "USA", "type": "text", "description": "Optional" },
								{ "key": "postalCode", "value": "10001", "type": "text", "description": "Optional" },
								{ "key": "profilePhoto", "type": "file", "src": [], "description": "REQUIRED: JPG or PNG, max 2MB" }
							]
						},
						"description": "DOCTOR ONLY. Requires multipart/form-data. profilePhoto is required (JPG/PNG, max 2MB). Forbidden fields: fullName, firstName, lastName, age, medicalHistory."
					}
				},
				{
					"name": "Get My Doctor Profile",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/doctors/profile",
						"description": "DOCTOR ONLY. Get the authenticated doctor's own profile."
					}
				},
				{
					"name": "Update Doctor Status (isActive)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/doctors/status",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"isActive\": true\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "DOCTOR ONLY. Toggle the doctor's availability status. isActive must be a boolean."
					}
				},
				{
					"name": "List All Doctors (Public)",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/doctors",
						"description": "Public endpoint. Lists all verified and active doctors."
					}
				},
				{
					"name": "Get Doctor by ID (Public)",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/doctors/{{doctorId}}",
						"description": "Get a single doctor's public profile. Non-admins can only view verified + active doctors."
					}
				},
				{
					"name": "Doctor's Appointments",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/doctors/appointments",
						"description": "DOCTOR ONLY. Returns the authenticated doctor's list of appointments."
					}
				}
			]
		},
		{
			"name": "3. Clients (Patient Onboarding)",
			"item": [
				{
					"name": "Setup Client - Step 1 (Personal Info)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/clients/setup",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"step\": 1,\n  \"name\": \"Jane Doe\",\n  \"gender\": \"female\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"phoneNumber\": \"+12025551234\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "CLIENT ONLY. Step 1 fields: name, gender, dateOfBirth, phoneNumber. Allowed gender: male | female | other."
					}
				},
				{
					"name": "Setup Client - Step 2 (Medical History)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/clients/setup",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"step\": 2,\n  \"medicalHistory\": \"Anxiety, mild depression\",\n  \"allergies\": \"Penicillin\",\n  \"currentMedications\": \"None\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "CLIENT ONLY. Step 2 fields: medicalHistory, allergies, currentMedications. Must complete step 1 first."
					}
				},
				{
					"name": "Setup Client - Step 3 (Emergency Contact)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/clients/setup",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"step\": 3,\n  \"emergencyContact\": {\n    \"name\": \"John Doe\",\n    \"phoneNumber\": \"+12025559999\"\n  }\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "CLIENT ONLY. Step 3 fields: emergencyContact (object with name and phoneNumber, both required). Completing step 3 marks the profile as completed."
					}
				},
				{
					"name": "Get Client Profile",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/clients/profile",
						"description": "CLIENT ONLY. Returns the authenticated client's profile."
					}
				},
				{
					"name": "Client Appointments",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/api/clients/appointments?status=scheduled",
							"host": ["{{baseUrl}}"],
							"path": ["api", "clients", "appointments"],
							"query": [{ "key": "status", "value": "scheduled", "description": "Optional filter: scheduled | completed | cancelled" }]
						},
						"description": "CLIENT ONLY. Get the authenticated client's appointment list. Optional ?status= filter."
					}
				}
			]
		},
		{
			"name": "4. Available Slots",
			"item": [
				{
					"name": "Get Available Slots for Doctor",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/api/appointments/available-slots?doctorId={{doctorId}}&fromDate=2026-05-01&toDate=2026-05-07",
							"host": ["{{baseUrl}}"],
							"path": ["api", "appointments", "available-slots"],
							"query": [
								{ "key": "doctorId", "value": "{{doctorId}}", "description": "Required" },
								{ "key": "fromDate", "value": "2026-05-01", "description": "Required. YYYY-MM-DD" },
								{ "key": "toDate", "value": "2026-05-07", "description": "Required. YYYY-MM-DD" }
							]
						},
						"description": "CLIENT ONLY. Fetch available booking slots for a specific doctor in a date range. All three query params are required."
					}
				},
				{
					"name": "Create Slot (Doctor)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/available-slots",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"slot_date\": \"2026-05-10\",\n  \"slot_time\": \"09:00:00\",\n  \"duration_minutes\": 60,\n  \"is_available\": true\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "DOCTOR ONLY. Create a new available slot. slot_date (YYYY-MM-DD), slot_time (HH:MM:SS), duration_minutes are required."
					}
				},
				{
					"name": "Get Slot by ID",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/available-slots/{{slotId}}",
						"description": "Get details of a specific available slot."
					}
				},
				{
					"name": "Get Doctor's Own Slots",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/available-slots/doctor/{{doctorId}}",
						"description": "DOCTOR ONLY. Get all slots created by this doctor (including unavailable ones)."
					}
				},
				{
					"name": "Update Slot",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/available-slots/{{slotId}}",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"slot_date\": \"2026-05-11\",\n  \"slot_time\": \"10:00:00\",\n  \"duration_minutes\": 45,\n  \"is_available\": true\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "DOCTOR ONLY. Update an existing slot."
					}
				},
				{
					"name": "Delete Slot",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/available-slots/{{slotId}}",
						"description": "DOCTOR ONLY. Delete an available slot."
					}
				}
			]
		},
		{
			"name": "5. Appointments",
			"item": [
				{
					"name": "Book Appointment (Client)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/appointments",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"scheduledDate\": \"2026-06-01\",\n  \"scheduledTime\": \"09:00\",\n  \"consultationType\": \"video\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "CLIENT ONLY. Book an appointment. Required: doctorId, scheduledDate (YYYY-MM-DD), scheduledTime (HH:MM). Optional: consultationType (video|audio), durationMinutes (default 50)."
					}
				},
				{
					"name": "Get Appointment by ID",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/appointments/{{appointmentId}}",
						"description": "Get full details of a specific appointment (doctor or client)."
					}
				},
				{
					"name": "Update Appointment",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/appointments/{{appointmentId}}",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"notes\": \"Updated notes for the appointment\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "Update appointment details."
					}
				},
				{
					"name": "Cancel Appointment",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/appointments/{{appointmentId}}/cancel",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"Schedule conflict\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "Cancel a scheduled appointment. Optional cancellation reason."
					}
				},
				{
					"name": "List All Appointments",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/appointments",
						"description": "List appointments for the authenticated user."
					}
				},
				{
					"name": "List Client Appointments",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/appointments/client",
						"description": "CLIENT ONLY. Get all appointments for the authenticated client."
					}
				},
				{
					"name": "List Doctor Appointments",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/appointments/doctor",
						"description": "DOCTOR ONLY. Get all appointments for the authenticated doctor."
					}
				}
			]
		},
		{
			"name": "6. Consultations",
			"item": [
				{
					"name": "Start Consultation",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/consultations/{{appointmentId}}/start",
						"description": "DOCTOR or CLIENT. Starts the consultation for a scheduled appointment. Appointment must be in 'scheduled' status."
					}
				},
				{
					"name": "End Consultation",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/consultations/{{appointmentId}}/end",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"notes\": \"Patient showed good progress. Follow-up in 2 weeks.\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "DOCTOR ONLY. Ends an in-progress consultation. Optional notes field for session summary."
					}
				},
				{
					"name": "Get Consultation Details",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/consultations/{{appointmentId}}",
						"description": "Get consultation details by appointment ID."
					}
				},
				{
					"name": "Client's Consultations",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/consultations/client",
						"description": "CLIENT ONLY. Get all consultations for the authenticated client."
					}
				},
				{
					"name": "Doctor's Consultations",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/consultations/doctor",
						"description": "DOCTOR ONLY. Get all consultations for the authenticated doctor."
					}
				}
			]
		},
		{
			"name": "7. Messages",
			"item": [
				{
					"name": "Send Message (Appointment-scoped)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/appointments/{{appointmentId}}/messages",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"content\": \"Hello Doctor, I have a quick question.\",\n  \"messageType\": \"text\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "DOCTOR or CLIENT. Send a text message within an appointment thread. Max 5000 chars. Only 'text' messageType supported in MVP."
					}
				},
				{
					"name": "Get Appointment Messages",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/api/appointments/{{appointmentId}}/messages?page=1&limit=50",
							"host": ["{{baseUrl}}"],
							"path": ["api", "appointments", "{{appointmentId}}", "messages"],
							"query": [
								{ "key": "page", "value": "1", "description": "Page number (default: 1)" },
								{ "key": "limit", "value": "50", "description": "Messages per page (max: 100, default: 50)" }
							]
						},
						"description": "DOCTOR or CLIENT. Get all messages in an appointment thread with pagination."
					}
				},
				{
					"name": "Send Standalone Message",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/messages",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"recipient_id\": \"2\",\n  \"content\": \"Hello, I wanted to reach out.\",\n  \"message_type\": \"text\",\n  \"subject\": \"General Inquiry\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "DOCTOR or CLIENT. Send a standalone message to any user by recipient_id. Fields: recipient_id (required), content or message_body (required), message_type, subject."
					}
				},
				{
					"name": "Get Inbox",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/messages/inbox",
						"description": "Get all received messages for the authenticated user."
					}
				},
				{
					"name": "Get Sent Messages",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/messages/sent",
						"description": "Get all sent messages for the authenticated user."
					}
				},
				{
					"name": "Get Message by ID",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/messages/{{messageId}}",
						"description": "Get a single message by its ID."
					}
				},
				{
					"name": "Mark Message as Read",
