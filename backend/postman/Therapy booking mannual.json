		{
			"name": "9. Validation & Errors",
			"item": [
				{
					"name": "Invalid Login (401)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": "{{baseUrl}}/api/auth/login",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"wrongpassword\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "Tests 401 Unauthorized. Expected: success=false, message='Invalid credentials'."
					}
				},
				{
					"name": "Missing Required Field (400)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"url": "{{baseUrl}}/api/auth/register",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"missing_fields@example.com\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "Tests 400 Bad Request for missing password/fullName. Returns 'errors' object with field details."
					}
				},
				{
					"name": "Forbidden Field in Profile (400)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/doctors/setup",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "fullName", "value": "Hacker Attempt", "type": "text" },
								{ "key": "gender", "value": "male", "type": "text" }
							]
						},
						"description": "Tests Rule 206: Identity fields (fullName) are forbidden in setup endpoints. Expected: 400 Bad Request."
					}
				},
				{
					"name": "Expired/Invalid Token (401)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer invalid_token_here" }],
						"url": "{{baseUrl}}/api/auth/me",
						"description": "Tests 401 Unauthorized with an invalid JWT. Expected: 'Token is invalid' or 'Unauthorized'."
					}
				},
				{
					"name": "Access Forbidden Resource (403)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/api/admin/doctors",
						"description": "Tests 403 Forbidden. Call this with a 'client' or 'doctor' token. Expected: 'Access denied' or 'Admin role required'."
					}
				},
				{
					"name": "Onboarding Hard Stop (400)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": "{{baseUrl}}/api/clients/setup",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"step\": 2,\n  \"medicalHistory\": \"Trying to skip step 1\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"description": "Tests migration/onboarding integrity. Skipping step 1 should result in a 400 error and reset onboarding_step."
					}
				},
				{
					"name": "Resource Not Found (404)",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/doctors/non_existent_id",
						"description": "Tests 404 Not Found for invalid resource IDs."
					}
				}
			]
		}
	]
