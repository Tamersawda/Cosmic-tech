          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "degree", "value": "MBBS", "type": "text" },
                { "key": "instituteName", "value": "Harvard Medical School", "type": "text" },
                { "key": "yearOfCompletion", "value": "2010", "type": "text" },
                { "key": "document", "type": "file", "src": "" }
              ]
