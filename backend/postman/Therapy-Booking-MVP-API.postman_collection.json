            "url": { "raw": "{{baseUrl}}/api/doctors/{{doctorId}}/qualifications", "host": ["{{baseUrl}}"], "path": ["api","doctors","{{doctorId}}","qualifications"] }
          }
        },
        {
          "name": "List Qualifications",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const d = pm.response.json();",
            "pm.test('data is array', () => pm.expect(d.data).to.be.an('array'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/doctors/{{doctorId}}/qualifications", "host": ["{{baseUrl}}"], "path": ["api","doctors","{{doctorId}}","qualifications"] }
          }
        },
        {
          "name": "Update Qualification",
          "request": {
