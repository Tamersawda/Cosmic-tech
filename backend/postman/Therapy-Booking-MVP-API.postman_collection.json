{
  "info": {
    "_postman_id": "cosmic-tech-v2",
    "name": "Cosmic-Tech Therapy API v2 (QA-Ready)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost/Cosmic-tech/backend", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "doctorId", "value": "", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" },
    { "key": "qualId", "value": "", "type": "string" },
    { "key": "expId", "value": "", "type": "string" },
    { "key": "appointmentId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Doctor",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json();",
            "if (d.success && d.data) {",
            "  pm.collectionVariables.set('token', d.data.token);",
            "  pm.collectionVariables.set('doctorId', d.data.userId);",
            "}",
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "pm.test('Has token', () => pm.expect(d.data.token).to.be.a('string'));",
            "pm.test('role=doctor', () => pm.expect(d.data.role).to.eql('doctor'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Dr. Test\",\n  \"email\": \"doctor@test.com\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"doctor\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "Register Client",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json();",
            "if (d.success && d.data) pm.collectionVariables.set('clientId', d.data.userId);",
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "pm.test('role=client', () => pm.expect(d.data.role).to.eql('client'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Client Test\",\n  \"email\": \"client@test.com\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"client\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "Login (stores token)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const d = pm.response.json();",
            "if (d.success && d.data) {",
            "  pm.collectionVariables.set('token', d.data.token);",
            "  pm.collectionVariables.set('doctorId', d.data.userId);",
            "}",
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Has token', () => pm.expect(d.data.token).to.be.a('string'));",
            "pm.test('Has role', () => pm.expect(d.data.role).to.be.a('string'));",
            "pm.test('No userType field', () => pm.expect(d.data.userType).to.be.undefined);",
            "pm.test('No fullName field', () => pm.expect(d.data.fullName).to.be.undefined);",
            "pm.test('Has Is_profile_complete', () => pm.expect(d.data.Is_profile_complete).to.be.a('boolean'));",
            "pm.test('Has Is_profile_approved', () => pm.expect(d.data.Is_profile_approved).to.be.a('boolean'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"doctor@test.com\",\n  \"password\": \"SecurePass123!\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Get Current User (me)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const d = pm.response.json();",
            "pm.test('Has userId', () => pm.expect(d.data.userId).to.be.a('string'));",
            "pm.test('Has name', () => pm.expect(d.data.name).to.be.a('string'));",
            "pm.test('Has role', () => pm.expect(d.data.role).to.be.a('string'));",
            "pm.test('Has Is_profile_complete', () => pm.expect(d.data.Is_profile_complete).to.be.a('boolean'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "Logout",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] }
          }
        },
        {
          "name": "[NEGATIVE] Register – missing role",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
            "const d = pm.response.json();",
            "pm.test('success=false', () => pm.expect(d.success).to.be.false);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"No Role\",\n  \"email\": \"norole@test.com\",\n  \"password\": \"Pass123!\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "[NEGATIVE] Login – wrong password",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"doctor@test.com\",\n  \"password\": \"WrongPass!\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        }
      ]
    },
    {
      "name": "2. Doctor Profile",
      "item": [
        {
          "name": "Setup Doctor Profile",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "gender", "value": "male", "type": "text" },
                { "key": "dateOfBirth", "value": "1985-06-15", "type": "text" },
                { "key": "phoneNumber", "value": "+1234567890", "type": "text" },
                { "key": "primarySpecialty", "value": "Psychiatry", "type": "text" },
                { "key": "yearsOfExperience", "value": "10", "type": "text" },
                { "key": "licenseNumber", "value": "LIC-99001", "type": "text" },
                { "key": "languagesSpoken", "value": "[\"English\"]", "type": "text" },
                { "key": "therapyTypes", "value": "[\"individual\", \"couple\"]", "type": "text" },
                { "key": "videoEnabled", "value": "true", "type": "text" },
                { "key": "videoRate", "value": "120", "type": "text" },
                { "key": "consultationDuration", "value": "60min", "type": "text" },
                { "key": "bufferTime", "value": "10min", "type": "text" },
                { "key": "profilePhoto", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/doctors/setup", "host": ["{{baseUrl}}"], "path": ["api","doctors","setup"] }
          }
        },
        {
          "name": "Get My Profile",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/doctors/profile", "host": ["{{baseUrl}}"], "path": ["api","doctors","profile"] }
          }
        },
        {
          "name": "List All Doctors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/doctors", "host": ["{{baseUrl}}"], "path": ["api","doctors"] }
          }
        },
        {
          "name": "Update Active Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"isActive\": true }", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/doctors/status", "host": ["{{baseUrl}}"], "path": ["api","doctors","status"] }
          }
        }
      ]
    },
    {
      "name": "3. Qualifications",
      "item": [
