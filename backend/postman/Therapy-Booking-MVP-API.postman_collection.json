            "body": { "mode": "raw", "raw": "{\n  \"degree\": \"Doctor of Medicine\",\n  \"instituteName\": \"Johns Hopkins\",\n  \"yearOfCompletion\": 2011\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/doctors/{{doctorId}}/qualifications/{{qualId}}", "host": ["{{baseUrl}}"], "path": ["api","doctors","{{doctorId}}","qualifications","{{qualId}}"] }
          }
        },
        {
          "name": "Delete Qualification",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/doctors/{{doctorId}}/qualifications/{{qualId}}", "host": ["{{baseUrl}}"], "path": ["api","doctors","{{doctorId}}","qualifications","{{qualId}}"] }
          }
        },
        {
          "name": "[NEGATIVE] Upload .php file",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 rejected', () => pm.response.to.have.status(400));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Malicious", "type": "text" },
                { "key": "document", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/doctors/{{doctorId}}/qualifications", "host": ["{{baseUrl}}"], "path": ["api","doctors","{{doctorId}}","qualifications"] }
          }
        }
      ]
    },
