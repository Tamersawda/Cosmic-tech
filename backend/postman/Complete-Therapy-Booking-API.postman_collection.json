              "raw": "{{baseUrl}}/api/auth/resend-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "resend-otp"]
            },
            "description": "Resend OTP to doctor email. Use this if OTP expires or user didn't receive it."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"OTP sent to email\",\n  \"data\": {\n    \"email\": \"doctor_1234567890@example.com\"\n  }\n}"
            }
          ]
