{
  "info": {
    "name": "Therapy Booking - Complete API (Phase 1-4)",
    "description": "Complete test collection for all phases: Authentication (1-2), Doctor/Patient Profiles & Slots (3), Appointments/Consultations/Messaging (4)",
    "version": "3.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
